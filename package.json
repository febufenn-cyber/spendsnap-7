{
  "name": "spendsnap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Receipt truth engine for auditable employee expense processing.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "check": "npm run typecheck && npm test",
    "evaluate": "npm run build && node scripts/evaluate-extractions.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.2",
    "hono": "4.12.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260713.1",
    "typescript": "5.9.3",
    "wrangler": "4.110.0"
  }
}
