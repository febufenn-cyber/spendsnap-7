# Copy to .dev.vars for local Wrangler development. Never commit real secrets.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=your-approved-model
RECEIPT_BUCKET=receipts
MAX_RECEIPT_BYTES=7500000
MAX_JSON_BYTES=1000000
EXTRACTION_PROMPT_VERSION=receipt-v1
AGENT_PROMPT_VERSION=agent-v1
ALLOWED_ORIGINS=http://localhost:5173
# Optional until a billing provider is integrated. Configure as a Worker secret in production.
BILLING_WEBHOOK_SECRET=replace-with-a-long-random-secret
BUILD_SHA=local
